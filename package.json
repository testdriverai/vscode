{
  "name": "testdriverai",
  "publisher": "testdriverai",
  "displayName": "TestDriver.ai",
  "description": "AI-powered end-to-end testing with live preview and MCP integration",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/testdriverai/testdriverai"
  },
  "version": "0.7.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "AI"
  ],
  "keywords": [
    "testing",
    "e2e",
    "end-to-end",
    "ai",
    "automation",
    "testdriver",
    "mcp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "walkthroughs": [
      {
        "id": "gettingStarted",
        "title": "Get Started with TestDriver",
        "description": "Set up AI-powered end-to-end testing in just a few minutes.",
        "steps": [
          {
            "id": "signup",
            "title": "Get a TestDriver API Key",
            "description": "An account is required to access TestDriver's AI model and cloud sandbox environments.\n[Get API Key](https://console.testdriver.ai/team)",
            "media": {
              "image": "media/main.png",
              "altText": "TestDriver main interface"
            },
            "completionEvents": [
              "openLink:https://console.testdriver.ai/team"
            ]
          },
          {
            "id": "init",
            "title": "Initialize TestDriver",
            "description": "Set up TestDriver in your workspace. This will create the config files, install dependencies, and configure the MCP server.\n[Initialize Project](command:testdriverai.initProject)",
            "media": {
              "image": "media/main.png",
              "altText": "TestDriver project initialization"
            },
            "completionEvents": [
              "onCommand:testdriverai.initProject"
            ]
          },
          {
            "id": "startChat",
            "title": "Write Your First Test",
            "description": "Start a conversation with the TestDriver agent in GitHub Copilot to create your first automated test.\n[Start Chat](command:testdriverai.startChat)",
            "media": {
              "image": "media/run.png",
              "altText": "Start chatting with TestDriver agent"
            },
            "completionEvents": [
              "onCommand:testdriverai.startChat"
            ]
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "testdriverai.openDebugger",
        "title": "TestDriver: Open Live Preview"
      },
      {
        "command": "testdriverai.closeDebugger",
        "title": "TestDriver: Close Live Preview"
      },
      {
        "command": "testdriverai.installMcp",
        "title": "TestDriver: Install MCP Server"
      },
      {
        "command": "testdriverai.walkthrough",
        "title": "TestDriver: Start Setup Walkthrough"
      },
      {
        "command": "testdriverai.initProject",
        "title": "TestDriver: Initialize Project"
      },
      {
        "command": "testdriverai.startChat",
        "title": "TestDriver: Start Chat with Agent"
      }
    ],
    "configuration": {
      "title": "TestDriver.ai",
      "properties": {
        "testdriverai.autoOpenPreview": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the live preview panel when a test starts"
        },
        "testdriverai.mcpServerPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to TestDriver MCP server (leave empty for default)"
        },
        "testdriverai.mcpPromptDismissed": {
          "type": "boolean",
          "default": false,
          "description": "Don't prompt to install MCP server"
        }
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.8",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0"
  }
}
